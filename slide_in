        def search():
            try:
                s_dt, e_dt = self.parse_dt(ent_s.get()), self.parse_dt(ent_e.get())
                _record_state(249, locals())
            except Exception as e:
                _ad_script_output(f'Line 249 Failed: {e}', is_error=True)
            try:
                dur = timedelta(minutes=int(ent_d.get()))
            except:
                return

            if not s_dt or not e_dt: return

            try:
                busy = sorted([a for a in self.schedule if a.end > s_dt and a.start < e_dt], key=lambda x: x.start)
                _record_state(257, locals())
            except Exception as e:
                _ad_script_output(f'Line 257 Failed: {e}', is_error=True)
            try:
                slots, curr = [], s_dt
                _record_state(258, locals())
            except Exception as e:
                _ad_script_output(f'Line 258 Failed: {e}', is_error=True)

            for act in busy:
                if curr < act.start and (act.start - curr) >= dur:
                    slots.append((curr, act.start))
                curr = max(curr, act.end)

            if curr < e_dt and (e_dt - curr) >= dur:
                slots.append((curr, e_dt))

            try:
                res_text.delete("1.0", tk.END)
                _record_state(268, locals())
            except Exception as e:
                _ad_script_output(f'Line 268 Failed: {e}', is_error=True)
            if not slots:
                res_text.insert(tk.END, "No free slots found.")
            else:
                for s, e in slots:
                    res_text.insert(tk.END, f"FREE: {s.strftime('%m/%d/%Y %H:%M')} TO {e.strftime('%m/%d/%Y %H:%M')}\n")

        try:
            tk.Button(container, text="SCAN FOR SLOTS", command=search, bg=ACCENT, pady=5).pack(fill="x", pady=10)
