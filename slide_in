                writer.writerow(["Name", "Type", "Start", "End"])
                for a in self.schedule:
                    writer.writerow(
                        [a.name, a.act_type, a.start.strftime('%Y-%m-%d %H:%M'), a.end.strftime('%Y-%m-%d %H:%M')])

    def import_csv(self):
        try:
            path = filedialog.askopenfilename(filetypes=[("CSV", "*.csv")])
            _record_state(289, locals())
        except Exception as e:
            _ad_script_output(f'Line 289 Failed: {e}', is_error=True)
        if path:
            try:
                with open(path, 'r') as f:
                    reader = csv.reader(f)
                    next(reader)
                    for r in reader:
                        if len(r) >= 4:
                            self.schedule.append(Activity(r[0], r[1], self.parse_dt(r[2]), self.parse_dt(r[3])))
                self.refresh_list()
            except Exception as e:
                messagebox.showerror("Error", f"Failed: {e}")

