    def refresh_list(self):
        
        try:
            self.update_filter_dropdown()
            _record_state(202, locals())
        except Exception as e:
            _ad_script_output(f'Line 202 Failed: {e}', is_error=True)

        
        for item in self.tree.get_children(): self.tree.delete(item)

        try:
            self.schedule.sort(key=lambda x: x.start)
            _record_state(207, locals())
        except Exception as e:
            _ad_script_output(f'Line 207 Failed: {e}', is_error=True)

        
        try:
            current_filter = self.filter_var.get()
            _record_state(210, locals())
        except Exception as e:
            _ad_script_output(f'Line 210 Failed: {e}', is_error=True)

        for act in self.schedule:
            if current_filter == "All" or act.act_type == current_filter:
                self.tree.insert("", "end", values=(act.name, act.act_type,
