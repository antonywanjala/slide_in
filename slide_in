    def parse_dt(self, dt_str):
        try:
            try:
                return datetime.strptime(dt_str.strip(), "%Y-%m-%d %H:%M")
                _record_state(157, locals())
            except Exception as e:
                _ad_script_output(f'Line 157 Failed: {e}', is_error=True)
        except:
            try:
                return None
                _record_state(159, locals())
            except Exception as e:
                _ad_script_output(f'Line 159 Failed: {e}', is_error=True)

    def check_overlap(self, start, end):
        try:
            overlaps = [a for a in self.schedule if (start < a.end and end > a.start)]
            _record_state(162, locals())
        except Exception as e:
            _ad_script_output(f'Line 162 Failed: {e}', is_error=True)
        try:
            return overlaps
            _record_state(163, locals())
        except Exception as e:
            _ad_script_output(f'Line 163 Failed: {e}', is_error=True)

    def add_activity(self):
        try:
            name, act_type = self.ent_name.get(), self.ent_type.get()
            _record_state(166, locals())
        except Exception as e:
            _ad_script_output(f'Line 166 Failed: {e}', is_error=True)
        try:
            start_dt, end_dt = self.parse_dt(self.ent_start.get()), self.parse_dt(self.ent_end.get())
            _record_state(167, locals())
        except Exception as e:
            _ad_script_output(f'Line 167 Failed: {e}', is_error=True)

        if not all([name, act_type, start_dt, end_dt]):
            try:
                messagebox.showerror("Error", "All fields required. Format: YYYY-MM-DD HH:MM")
                _record_state(170, locals())
            except Exception as e:
                _ad_script_output(f'Line 170 Failed: {e}', is_error=True)
            try:
                return
                _record_state(171, locals())
            except Exception as e:
                _ad_script_output(f'Line 171 Failed: {e}', is_error=True)

        if start_dt >= end_dt:
            try:
                messagebox.showerror("Error", "End time must be after start time.")
                _record_state(174, locals())
            except Exception as e:
                _ad_script_output(f'Line 174 Failed: {e}', is_error=True)
            try:
                return
                _record_state(175, locals())
            except Exception as e:
                _ad_script_output(f'Line 175 Failed: {e}', is_error=True)

        
        try:
            overlaps = self.check_overlap(start_dt, end_dt)
            _record_state(178, locals())
        except Exception as e:
            _ad_script_output(f'Line 178 Failed: {e}', is_error=True)
        if overlaps:
            try:
                overlap_names = ", ".join([a.name for a in overlaps])
                _record_state(180, locals())
            except Exception as e:
                _ad_script_output(f'Line 180 Failed: {e}', is_error=True)
            
            confirm = messagebox.askyesno("Conflict Detected",
                                          f"This overlaps with: {overlap_names}.\n\nAllow multiple tasks at this time?")
            if not confirm:
                return

        try:
            self.schedule.append(Activity(name, act_type, start_dt, end_dt))
            _record_state(187, locals())
        except Exception as e:
            _ad_script_output(f'Line 187 Failed: {e}', is_error=True)
        try:
            self.refresh_list()
            _record_state(188, locals())
        except Exception as e:
            _ad_script_output(f'Line 188 Failed: {e}', is_error=True)
        for e in [self.ent_name, self.ent_type, self.ent_start, self.ent_end]: e.delete(0, tk.END)

